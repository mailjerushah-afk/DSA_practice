class Solution:
    def maxOperations(self, nums: List[int], k: int) -> int:
        if nums is None:
            return 0
        
        operations = 0
        nums.sort()
        left, right = 0, len(nums) - 1
        while left < right:
            current_sum = nums[left] + nums[right]
            if current_sum == k:
                operations +=1
                left+= 1
                right -= 1
            elif current_sum < k:
                left +=1
            else:
                right -=1
        return operations
        
